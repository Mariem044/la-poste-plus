{
  "include": ["src/**/*.ts", "src/**/*.tsx", "vite.config.js", "eslint.config.js", "src/context/AuthContext.jsx", "src/hooks/use-mobile.jsx", "src/lib/utils.js", "src/components/Logo.jsx", "src/components/Header.jsx", "src/components/Sidebar.jsx"],
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],

    /* Bundler mode */
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "noEmit": true,

    /* Linting */
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
